<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="MonthTabStyle">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:layout_marginHorizontal">4dp</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="TabItemStyleInactive">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">@color/tab_text_inactive</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TabItemStyleActive" parent="TabItemStyleInactive">
        <item name="android:background">@drawable/bg_tab_active</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Theme.SolusyonInternetServiceProvider" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
    </style>

    <style name="ShapeAppearance.Circular" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>