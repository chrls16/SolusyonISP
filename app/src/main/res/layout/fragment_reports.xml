<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports and Analytics"
            android:textColor="#0F172A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Real-time performance data and subscriber growth trends."
            android:textColor="#64748B"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#F1F5F9"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/lblSubscribers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL SUBSCRIBERS"
                    android:textAllCaps="true"
                    android:textColor="#64748B"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalSubscribers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblSubscribers"
                    android:layout_marginTop="16dp"
                    android:text="12,482"
                    android:textColor="#1E293B"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvTotalSubscribers"
                    android:layout_marginTop="8dp"
                    android:text="↗ +8.4% this month"
                    android:textColor="#059669" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg_blue"
                    android:padding="12dp"
                    android:src="@drawable/ic_subscribers" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#F1F5F9"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/lblMonthlyRev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHLY REVENUE"
                    android:textAllCaps="true"
                    android:textColor="#64748B"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMonthlyRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblMonthlyRev"
                    android:layout_marginTop="16dp"
                    android:text="₱0.00"
                    android:textColor="#0369A1"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvMonthlyRevenue"
                    android:layout_marginTop="8dp"
                    android:text="↗ +0.0% from last month"
                    android:textColor="#059669" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg_blue_light"
                    android:padding="12dp"
                    android:src="@drawable/ic_revenue_monthly" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#F1F5F9"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/lblAnnualRev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANNUAL REVENUE"
                    android:textAllCaps="true"
                    android:textColor="#64748B"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAnnualRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblAnnualRev"
                    android:layout_marginTop="16dp"
                    android:text="₱0.00"
                    android:textColor="#0369A1"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvAnnualRevenue"
                    android:layout_marginTop="8dp"
                    android:text="Forecast: ₱0.00"
                    android:textColor="#92400E" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg_orange_light"
                    android:padding="12dp"
                    android:src="@drawable/ic_revenue_annual" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>