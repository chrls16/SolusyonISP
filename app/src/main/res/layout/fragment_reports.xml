<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports and Analytics"
            android:textColor="#0F172A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Real-time performance data and subscriber growth trends."
            android:textColor="#64748B"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/lblSubscribers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL SUBSCRIBERS"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalSubscribers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblSubscribers"
                    android:layout_marginTop="16dp"
                    android:text=""
                    android:textColor="#0E3C7E"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvTotalSubscribers"
                    android:layout_marginTop="8dp"
                    android:text="↗ % this month"
                    android:textColor="#059669" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg_blue_light"
                    android:padding="10dp"
                    android:src="@drawable/ic_subscribers"
                    app:tint="#0E3C7E" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/lblMonthlyRev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHLY REVENUE"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMonthlyRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblMonthlyRev"
                    android:layout_marginTop="16dp"
                    android:text="₱"
                    android:textColor="#0E3C7E"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvMonthlyRevenue"
                    android:layout_marginTop="8dp"
                    android:text="↗ % from last month"
                    android:textColor="#059669" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg_blue_light"
                    android:padding="10dp"
                    android:src="@drawable/ic_revenue_monthly"
                    app:tint="#0E3C7E" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/lblAnnualRev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANNUAL REVENUE"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAnnualRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblAnnualRev"
                    android:layout_marginTop="16dp"
                    android:text="₱"
                    android:textColor="#0E3C7E"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvAnnualRevenue"
                    android:layout_marginTop="8dp"
                    android:text="📊 Forecast: ₱"
                    android:textColor="#92400E" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg_orange_light"
                    android:padding="10dp"
                    android:src="@drawable/ic_revenue_annual"
                    app:tint="#92400E" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/layoutGrowthFilters"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Subscription\nGrowth"
                            android:textColor="#0F172A"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="New net activations over the last year"
                            android:textColor="#64748B"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutGrowthFilters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnFilter6Months"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_filter_selected"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="12dp"
                            android:text="6\nMonths"
                            android:textAlignment="center"
                            android:textColor="#0E3C7E"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnFilter1Year"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="1\nYear"
                            android:textAlignment="center"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/reportingLineChart"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginTop="32dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:id="@+id/monthContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView android:id="@+id/monthJan" style="@style/MonthTabStyle" android:text="JAN" />
                        <TextView android:id="@+id/monthFeb" style="@style/MonthTabStyle" android:text="FEB" />
                        <TextView android:id="@+id/monthMar" style="@style/MonthTabStyle" android:text="MAR" />
                        <TextView android:id="@+id/monthApr" style="@style/MonthTabStyle" android:text="APR" />
                        <TextView android:id="@+id/monthMay" style="@style/MonthTabStyle" android:text="MAY" />
                        <TextView android:id="@+id/monthJun" style="@style/MonthTabStyle" android:text="JUN" />
                        <TextView android:id="@+id/monthJul" style="@style/MonthTabStyle" android:text="JUL" />
                        <TextView android:id="@+id/monthAug" style="@style/MonthTabStyle" android:text="AUG" />
                        <TextView android:id="@+id/monthSep" style="@style/MonthTabStyle" android:text="SEP" />
                        <TextView android:id="@+id/monthOct" style="@style/MonthTabStyle" android:text="OCT" />
                        <TextView android:id="@+id/monthNov" style="@style/MonthTabStyle" android:text="NOV" />
                        <TextView android:id="@+id/monthDec" style="@style/MonthTabStyle" android:text="DEC" />

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Regional Distribution"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MANILA SOUTH" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="42%" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
                </RelativeLayout>
                <ProgressBar
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progress="42"
                    android:progressDrawable="@drawable/progress_blue" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QUEZON CITY" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="28%" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
                </RelativeLayout>
                <ProgressBar
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progress="28"
                    android:progressDrawable="@drawable/progress_teal" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TAGUIG / BGC" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="15%" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
                </RelativeLayout>
                <ProgressBar
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progress="15"
                    android:progressDrawable="@drawable/progress_brown" />

                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="VIEW MAP DETAILS"
                    android:textColor="#0E3C7E"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#FFFFFF"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>