<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:id="@+id/statusContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_approved"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/statusIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_check_circle"
                app:tint="#2D6A4F" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/statusIcon"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APPLICATION STATUS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#2D6A4F"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1B4332" />

                <TextView
                    android:id="@+id/tvStatusDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your internet service request has\nbeen processed and verified."
                    android:textColor="#40916C"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_receipt_card"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="2dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_receipt_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:text="Digital Application Receipt"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Solusyon Internet Services • Daet, CN"
                android:textColor="#64748B"
                android:textSize="12sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="#EFF6FF"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelAppID"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APPLICATION ID"
                    android:textSize="10sp"
                    android:textColor="#3B82F6"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvReceiptID"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/labelAppID"
                    android:text="SOL-2026-884921"
                    android:textColor="#1E40AF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDateIssued"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_below="@id/labelAppID"
                    android:text="Apr 23, 2026"
                    android:textColor="#1E3A8A"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="👤 APPLICANT INFORMATION"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#475569" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FULL NAME" android:textSize="10sp" android:layout_marginTop="12dp" />
            <TextView android:id="@+id/tvReceiptName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Elena Rodriguez Garcia" android:textStyle="bold" android:textColor="#0F172A" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PHONE NUMBER" android:textSize="10sp" android:layout_marginTop="12dp" />
            <TextView android:id="@+id/tvReceiptPhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+63 917 555 0123" android:textStyle="bold" android:textColor="#0F172A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="📡 CHOSEN PLAN DETAILS"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#475569" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F8FAFC"
                android:padding="16dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvPlanName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Standard Fiber Plan"
                    android:textColor="#1E40AF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="₱699"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="💳 MODE OF PAYMENT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#475569" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <ImageView
                    android:id="@+id/imgPaymentLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_gcash" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:id="@+id/tvPaymentName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GCash" android:textStyle="bold" />
                    <TextView android:id="@+id/tvPaymentDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wallet ID: 0917****123" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#1D4ED8"
            android:text="Proceed to Create Account  →"
            android:textAllCaps="false"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btnSavePDF"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#EFF6FF"
            android:text="⬇ Save Receipt as PDF"
            android:textColor="#1E40AF"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>